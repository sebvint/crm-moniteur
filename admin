function renderInventaires(){
  var c=g('content');c.innerHTML='';

  // KPIs
  var total=INVPLAN.length;
  var realises=INVPLAN.filter(function(i){return i.statut==='Réalisé';}).length;
  var annules=INVPLAN.filter(function(i){return i.statut==='Annulé';}).length;
  var now=new Date();
  var enRetard=INVPLAN.filter(function(i){return i.statut!=='Réalisé'&&i.statut!=='Annulé'&&i.date_prevue&&new Date(i.date_prevue)<now;}).length;
  var tauxReal=total>0?Math.round(realises/total*100):0;

  var kpiDiv=document.createElement('div');kpiDiv.className='kpi-grid';
  [{l:'Total planifiés',v:total,s:''},{l:'Réalisés',v:realises,s:'color:var(--vert)'},{l:'Taux réalisation',v:tauxReal+'%',s:tauxReal>=80?'color:var(--vert)':tauxReal>=60?'color:var(--orange)':'color:var(--rouge)'},{l:'En retard',v:enRetard,s:enRetard>0?'color:var(--rouge)':''},{l:'Annulés',v:annules,s:'color:#999'}].forEach(function(k){
    var d=document.createElement('div');d.className='kpi';
    d.innerHTML='<div class="kpi-lbl">'+k.l+'</div><div class="kpi-val" style="'+k.s+'">'+k.v+'</div>';
    kpiDiv.appendChild(d);
  });
  c.appendChild(kpiDiv);

  // Par magasin
  var card=document.createElement('div');card.className='card';
  card.innerHTML='<div class="card-hdr"><span class="card-title">Suivi par magasin</span></div>';
  var tbl=document.createElement('table');
  tbl.innerHTML='<thead><tr><th>Magasin</th><th>Planifiés</th><th>Réalisés</th><th>Dernier inventaire</th><th>Résultat RI</th><th>Dém. inconnue</th></tr></thead>';
  var tb=document.createElement('tbody');

  var byMag={};
  INVPLAN.forEach(function(i){if(!byMag[i.code])byMag[i.code]={plan:0,real:0,nom:i.mag||i.code};byMag[i.code].plan++;if(i.statut==='Réalisé')byMag[i.code].real++;});

  MAGS.filter(function(m){return m.statut==='Actif'||m.statut==='Surveillance';}).forEach(function(mg){
    var bm=byMag[mg.code]||{plan:0,real:0};
    var lastInv=INVS.filter(function(i){return i.code===mg.code;}).sort(function(a,b){return b.date_inventaire>a.date_inventaire?1:-1;})[0]||null;
    var tx=bm.plan>0?Math.round(bm.real/bm.plan*100):null;
    var tr=document.createElement('tr');
    tr.innerHTML='<td><span class="tf">'+mg.code+'</span> '+mg.nom+'</td><td>'+bm.plan+'</td><td>'+(tx!==null?'<span class="pill '+(tx>=80?'pill-g':tx>=50?'pill-or':'pill-r')+'">'+bm.real+' ('+tx+'%)</span>':'<span style="color:#CCC">0</span>')+'</td><td>'+(lastInv?fmt(lastInv.date_inventaire):'<span style="color:#CCC">Jamais</span>')+'</td><td>'+(lastInv&&lastInv.resultat_ri!=null?'<span style="color:'+(lastInv.resultat_ri<0?'var(--rouge)':'var(--vert)')+'">'+fmtEuro(lastInv.resultat_ri)+'</span>':'--')+'</td><td>'+(lastInv&&lastInv.dmq_inconnue_pct!=null?'<span style="color:'+(lastInv.dmq_inconnue_pct>2?'var(--rouge)':'var(--vert)')+'">'+lastInv.dmq_inconnue_pct.toFixed(2)+'%</span>':'--')+'</td>';
    tb.appendChild(tr);
  });
  tbl.appendChild(tb);card.appendChild(tbl);c.appendChild(card);
}

