<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>ProxiPilot — Back Office</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#F0F0F0;color:#111;display:flex;min-height:100vh;}
:root{--or:#C9921A;--orl:#FDF7E8;--orb:#E8D080;--rouge:#D94040;--rougel:#FDF0F0;--rougeb:#F0C0C0;--orange:#D07030;--orangel:#FEF5EC;--orangeb:#ECC890;--vert:#2E8050;--vertl:#F0F9F4;--vertb:#98D0B0;--bleu:#1D4ED8;--bleul:#EFF6FF;--bleub:#93C5FD;--violet:#5B21B6;--violetl:#F5F3FF;--violetb:#C4B5FD;--card:#fff;--bg:#F0F0F0;--bord:#EBEBEB;--bord2:#F5F5F5;--sidebar:220px;}
button,input,select,textarea{font-family:inherit;outline:none;}

/* ===== SIDEBAR ===== */
#sidebar{width:var(--sidebar);background:#111;display:flex;flex-direction:column;height:100vh;position:sticky;top:0;flex-shrink:0;}
.sb-logo{display:flex;align-items:center;gap:9px;padding:16px 14px;border-bottom:1px solid #222;}
.sb-title{font-size:14px;font-weight:700;color:#fff;}.sb-title span{color:var(--or);}
.sb-subtitle{font-size:8px;color:#555;text-transform:uppercase;letter-spacing:.06em;margin-top:1px;}
.sb-nav{flex:1;padding:10px 8px;overflow-y:auto;}
.sb-sec{font-size:9px;font-weight:600;color:#444;text-transform:uppercase;letter-spacing:.06em;padding:10px 10px 4px;margin-top:6px;}
.sb-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:7px;font-size:12px;color:#888;cursor:pointer;border:none;background:none;width:100%;text-align:left;transition:.15s;}
.sb-item:hover{background:#1A1A1A;color:#ccc;}
.sb-item.on{background:var(--orl);color:var(--or);font-weight:600;}
.sb-item.on svg{stroke:var(--or);}
.sb-badge-r{margin-left:auto;background:var(--rouge);color:#fff;padding:0 6px;border-radius:10px;font-size:9px;font-weight:700;}
.sb-bot{border-top:1px solid #222;padding:12px 14px;}
.sb-user{display:flex;align-items:center;gap:9px;}
.sb-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;}
.sb-nm{font-size:11px;font-weight:600;color:#fff;}
.sb-rl{font-size:10px;color:#555;}
.sb-back{display:flex;align-items:center;gap:6px;padding:7px 10px;border-radius:7px;font-size:11px;color:#555;cursor:pointer;border:1px solid #222;background:none;width:100%;margin-bottom:8px;}
.sb-back:hover{border-color:#444;color:#888;}

/* ===== MAIN ===== */
#main{flex:1;overflow-y:auto;height:100vh;display:flex;flex-direction:column;}
.topbar{background:#fff;border-bottom:1px solid var(--bord);display:flex;align-items:center;padding:0 24px;height:52px;flex-shrink:0;gap:12px;position:sticky;top:0;z-index:100;}
.topbar-title{font-size:15px;font-weight:700;color:#111;flex:1;}
.topbar-sub{font-size:11px;color:#999;}
.content{padding:20px 24px;flex:1;}

/* ===== CARDS & TABLES ===== */
.card{background:var(--card);border:1px solid var(--bord);border-radius:12px;margin-bottom:16px;overflow:hidden;}
.card-hdr{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--bord2);}
.card-title{font-size:13px;font-weight:700;color:#111;}
.kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px;}
.kpi{background:var(--card);border:1px solid var(--bord);border-radius:12px;padding:14px;}
.kpi-lbl{font-size:9px;color:#999;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;}
.kpi-val{font-size:24px;font-weight:700;color:#111;line-height:1;}
.kpi-sub{font-size:10px;color:#999;margin-top:4px;}
table{width:100%;border-collapse:collapse;}
th{font-size:10px;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:.04em;padding:9px 12px;text-align:left;border-bottom:1px solid var(--bord);background:#FAFAFA;white-space:nowrap;}
td{padding:10px 12px;border-bottom:1px solid var(--bord2);font-size:12px;vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:#FAFAFA;cursor:pointer;}
.pill{display:inline-block;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:700;}
.pill-r{background:var(--rougel);color:var(--rouge);border:1px solid var(--rougeb);}
.pill-o{background:var(--orangel);color:var(--orange);border:1px solid var(--orangeb);}
.pill-g{background:var(--vertl);color:var(--vert);border:1px solid var(--vertb);}
.pill-or{background:var(--orl);color:var(--or);border:1px solid var(--orb);}
.pill-n{background:#F5F5F5;color:#777;border:1px solid #E0E0E0;}
.pill-b{background:var(--bleul);color:var(--bleu);border:1px solid var(--bleub);}
.pill-v{background:var(--violetl);color:var(--violet);border:1px solid var(--violetb);}
.tf{background:#111;color:var(--or);padding:2px 6px;border-radius:4px;font-size:8px;font-weight:700;}

/* ===== BOUTONS ===== */
.btn{padding:7px 14px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:1px solid;display:inline-flex;align-items:center;gap:5px;transition:.15s;}
.btn-primary{background:#111;color:var(--or);border-color:var(--or);}
.btn-primary:hover{background:#1A1A1A;}
.btn-ghost{background:var(--card);color:#666;border-color:var(--bord);}
.btn-ghost:hover{background:#F8F8F8;}
.btn-danger{background:var(--rougel);color:var(--rouge);border-color:var(--rougeb);}
.btn-sm{padding:4px 10px;font-size:10px;}

/* ===== FORMULAIRES ===== */
.form-row{display:grid;gap:12px;margin-bottom:12px;}
.form-row.cols2{grid-template-columns:1fr 1fr;}
.form-row.cols3{grid-template-columns:1fr 1fr 1fr;}
.ff{display:flex;flex-direction:column;gap:5px;}
.fl{font-size:11px;font-weight:600;color:#666;}
input[type=text],input[type=date],input[type=number],input[type=time],select,textarea{padding:8px 10px;border:1px solid var(--bord);border-radius:7px;font-size:12px;color:#111;background:#FAFAFA;width:100%;}
input:focus,select:focus,textarea:focus{border-color:var(--or);background:#fff;outline:none;}

/* ===== CALENDRIER ===== */
.cal-wrap{overflow:hidden;}
.cal-nav{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--bord2);}
.cal-title{font-size:14px;font-weight:700;color:#111;}
.cal-days-hdr{display:grid;grid-template-columns:repeat(7,1fr);background:#FAFAFA;border-bottom:1px solid var(--bord2);}
.cal-dh{text-align:center;font-size:9px;font-weight:600;color:#999;padding:6px;text-transform:uppercase;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);}
.cal-cell{border-right:1px solid var(--bord2);border-bottom:1px solid var(--bord2);padding:4px;min-height:80px;}
.cal-cell:nth-child(7n){border-right:none;}
.cal-num{font-size:10px;color:#999;font-weight:500;margin-bottom:3px;}
.cal-num.today{width:18px;height:18px;background:#111;color:var(--or);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;}
.cal-num.past{color:#DDD;}
.cal-ev{border-radius:3px;padding:2px 4px;font-size:8px;font-weight:600;margin-bottom:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:pointer;}
.cal-ev:hover{opacity:.85;}
.ev-c{background:var(--orl);color:#854F0B;border-left:2px solid var(--or);}
.ev-k{background:var(--vertl);color:#27500A;border-left:2px solid var(--vert);}
.ev-cg{background:var(--bleul);color:#0C447C;border-left:2px solid var(--bleu);}
.ev-in{background:var(--violetl);color:#3C3489;border-left:2px solid var(--violet);}
.ev-vi{background:#F5F5F5;color:#555;border-left:2px solid #999;}
.cal-leg{display:flex;gap:12px;flex-wrap:wrap;padding:10px 16px;border-top:1px solid var(--bord2);}
.leg-item{display:flex;align-items:center;gap:5px;font-size:10px;color:#777;}
.leg-dot{width:8px;height:8px;border-radius:2px;}

/* ===== MODALE ===== */
.modal-ov{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:500;align-items:center;justify-content:center;}
.modal-ov.on{display:flex;}
.modal{background:var(--card);border-radius:14px;padding:24px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;border-top:3px solid var(--or);position:relative;}
.modal h3{font-size:16px;font-weight:700;color:#111;margin-bottom:16px;}
.modal-close{position:absolute;top:16px;right:16px;background:none;border:none;cursor:pointer;color:#999;font-size:18px;line-height:1;}
.modal-footer{display:flex;gap:8px;margin-top:20px;justify-content:flex-end;}

/* ===== STEPPER ===== */
.stepper{display:flex;gap:0;margin-bottom:24px;}
.step{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;}
.step::after{content:'';position:absolute;top:14px;left:50%;right:-50%;height:2px;background:var(--bord);z-index:0;}
.step:last-child::after{display:none;}
.step-num{width:28px;height:28px;border-radius:50%;background:var(--bord);color:#999;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;z-index:1;position:relative;}
.step.done .step-num{background:var(--vert);color:#fff;}
.step.active .step-num{background:#111;color:var(--or);}
.step-lbl{font-size:9px;color:#999;margin-top:4px;text-align:center;}
.step.active .step-lbl{color:#111;font-weight:600;}

/* ===== LOADER ===== */
.lov{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.8);z-index:600;align-items:center;justify-content:center;}
.lov.on{display:flex;}
.spin{width:34px;height:34px;border:3px solid var(--bord);border-top-color:var(--or);border-radius:50%;animation:sp .8s linear infinite;}
@keyframes sp{to{transform:rotate(360deg);}}

/* ===== TABS SECONDAIRES ===== */
.tabs2{display:flex;border-bottom:1px solid var(--bord);margin-bottom:16px;gap:0;}
.tab2{padding:10px 16px;font-size:12px;font-weight:500;color:#999;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;}
.tab2.on{color:#111;font-weight:700;border-bottom-color:#111;}
.tab2:hover:not(.on){color:#666;}

/* ===== DIVERS ===== */
.empty{text-align:center;color:#CCC;padding:32px;font-size:12px;}
.tag{display:inline-flex;align-items:center;gap:4px;background:#F5F5F5;border:1px solid #E0E0E0;border-radius:4px;padding:3px 8px;font-size:10px;color:#666;}
.tag-del{cursor:pointer;color:#999;}
.tag-del:hover{color:var(--rouge);}
.stat-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--bord2);}
.stat-row:last-child{border-bottom:none;}
</style>
</head>
<body>

