// ============================================================
// FORMULAIRE INVENTAIRE (4 étapes)
// ============================================================
var INV_STEP=1,INV_DATA={};
function ouvrirFormInv(prefill){
  INV_STEP=1;INV_DATA=prefill||{};
  g('mod-inv-title').textContent='Planifier un inventaire';
  renderInvStep();openM('mod-inv');
}
function editerInv(id){
  var inv=INVPLAN.find(function(i){return i.id===id;});if(!inv)return;
  INV_DATA=Object.assign({},inv);INV_DATA._id=id;
  INV_STEP=1;g('mod-inv-title').textContent='Modifier l\'inventaire';
  renderInvStep();openM('mod-inv');
}
function renderInvStep(){
  var body=g('mod-inv-body');body.innerHTML='';
  // Stepper
  var stepper=document.createElement('div');stepper.className='stepper';
  ['Général','Participants','Planification','Validation'].forEach(function(s,i){
    var step=document.createElement('div');step.className='step'+(i+1<INV_STEP?' done':i+1===INV_STEP?' active':'');
    step.innerHTML='<div class="step-num">'+(i+1<INV_STEP?'✓':i+1)+'</div><div class="step-lbl">'+s+'</div>';
    stepper.appendChild(step);
  });
  body.appendChild(stepper);

  if(INV_STEP===1){
    var h=document.createElement('div');
    var selMag=document.createElement('select');selMag.id='si-mag';
    var o0=document.createElement('option');o0.value='';o0.textContent='-- Choisir un magasin --';selMag.appendChild(o0);
    MAGS.filter(function(m){return m.statut==='Actif'||m.statut==='Surveillance';}).forEach(function(m){
      var o=document.createElement('option');o.value=m.code;o.setAttribute('data-nom',m.nom);o.textContent=m.code+' - '+m.nom;
      if(INV_DATA.code===m.code)o.selected=true;selMag.appendChild(o);
    });
    var selType=document.createElement('select');selType.id='si-type';
    ['Cession','Contrôle','Visite','Congés','Intervention'].forEach(function(t){
      var o=document.createElement('option');o.value=t;o.textContent=t;if(INV_DATA.motif===t)o.selected=true;selType.appendChild(o);
    });
    var notesTA=document.createElement('textarea');notesTA.id='si-notes';notesTA.rows=2;notesTA.value=INV_DATA.notes||'';notesTA.placeholder='Informations complémentaires...';
    h.innerHTML='<div class="form-row"><div class="ff"><label class="fl">Magasin <span style="color:var(--rouge)">*</span></label></div></div>';
    var ffMag=document.createElement('div');ffMag.className='ff';ffMag.innerHTML='<label class="fl">Magasin *</label>';ffMag.appendChild(selMag);
    var ffType=document.createElement('div');ffType.className='ff';ffType.innerHTML='<label class="fl">Type d\'événement</label>';ffType.appendChild(selType);
    var ffNotes=document.createElement('div');ffNotes.className='ff';ffNotes.innerHTML='<label class="fl">Notes</label>';ffNotes.appendChild(notesTA);
    h.innerHTML='';h.appendChild(ffMag);h.appendChild(ffType);h.appendChild(ffNotes);body.appendChild(h);
    var footer=document.createElement('div');footer.className='modal-footer';
    var btnNext=document.createElement('button');btnNext.className='btn btn-primary';btnNext.textContent='Suivant →';
    btnNext.onclick=function(){
      var sel=g('si-mag');if(!sel||!sel.value){alert('Choisissez un magasin');return;}
      var opt=sel.options[sel.selectedIndex];INV_DATA.code=sel.value;INV_DATA.mag=opt.getAttribute('data-nom')||sel.value;
      INV_DATA.motif=gv('si-type');INV_DATA.notes=gv('si-notes');INV_STEP=2;renderInvStep();
    };
    footer.appendChild(btnNext);body.appendChild(footer);

  }else if(INV_STEP===2){
    INV_DATA.personnes=INV_DATA.personnes||'';
    var persDiv=document.createElement('div');
    var moniteurs=USERS.map(function(u){return u.nom;});
    var piloteSelect=document.createElement('select');piloteSelect.id='si-pilote';
    var o0=document.createElement('option');o0.value='';o0.textContent='-- Pilote --';piloteSelect.appendChild(o0);
    moniteurs.forEach(function(m){var o=document.createElement('option');o.value=m;o.textContent=m;piloteSelect.appendChild(o);});
    var addName=document.createElement('input');addName.type='text';addName.id='si-add-name';addName.placeholder='Ajouter un participant...';
    var tagsList=document.createElement('div');tagsList.id='si-tags';tagsList.style.cssText='display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;min-height:32px';
    var ffP=document.createElement('div');ffP.className='ff';ffP.innerHTML='<label class="fl">Pilote</label>';ffP.appendChild(piloteSelect);
    var ffAdd=document.createElement('div');ffAdd.className='ff';ffAdd.innerHTML='<label class="fl">Participants supplémentaires</label>';ffAdd.appendChild(addName);
    persDiv.appendChild(ffP);persDiv.appendChild(ffAdd);persDiv.appendChild(tagsList);body.appendChild(persDiv);

    var tags=INV_DATA.personnes?INV_DATA.personnes.split(';').filter(Boolean):[];
    function renderTags(){tagsList.innerHTML='';tags.forEach(function(t,i){var tg=document.createElement('span');tg.className='tag';tg.innerHTML=t+' <span class="tag-del" data-i="'+i+'">✕</span>';tg.querySelector('.tag-del').onclick=function(){tags.splice(parseInt(this.getAttribute('data-i')),1);renderTags();};tagsList.appendChild(tg);});}
    renderTags();
    addName.onkeydown=function(e){if(e.key==='Enter'&&this.value.trim()){tags.push(this.value.trim());this.value='';renderTags();}};
    var footer=document.createElement('div');footer.className='modal-footer';
    var btnPrev=document.createElement('button');btnPrev.className='btn btn-ghost';btnPrev.textContent='← Retour';btnPrev.onclick=function(){INV_STEP=1;renderInvStep();};
    var btnNext=document.createElement('button');btnNext.className='btn btn-primary';btnNext.textContent='Suivant →';
    btnNext.onclick=function(){
      var pilote=gv('si-pilote');var all=[pilote].concat(tags).filter(Boolean);INV_DATA.personnes=all.join(';');INV_STEP=3;renderInvStep();
    };
    footer.appendChild(btnPrev);footer.appendChild(btnNext);body.appendChild(footer);

  }else if(INV_STEP===3){
    var dateInp=document.createElement('input');dateInp.type='date';dateInp.id='si-date';dateInp.value=INV_DATA.date_prevue||'';
    var statSelect=document.createElement('select');statSelect.id='si-statut';
    ['Planifié','Réalisé','Annulé'].forEach(function(s){var o=document.createElement('option');o.value=s;o.textContent=s;if(INV_DATA.statut===s)o.selected=true;statSelect.appendChild(o);});
    var ffDate=document.createElement('div');ffDate.className='ff';ffDate.innerHTML='<label class="fl">Date prévue *</label>';ffDate.appendChild(dateInp);
    var ffStat=document.createElement('div');ffStat.className='ff';ffStat.innerHTML='<label class="fl">Statut</label>';ffStat.appendChild(statSelect);
    var row=document.createElement('div');row.className='form-row cols2';row.appendChild(ffDate);row.appendChild(ffStat);body.appendChild(row);
    var footer=document.createElement('div');footer.className='modal-footer';
    var btnPrev=document.createElement('button');btnPrev.className='btn btn-ghost';btnPrev.textContent='← Retour';btnPrev.onclick=function(){INV_STEP=2;renderInvStep();};
    var btnNext=document.createElement('button');btnNext.className='btn btn-primary';btnNext.textContent='Suivant →';
    btnNext.onclick=function(){if(!gv('si-date')){alert('Choisissez une date');return;}INV_DATA.date_prevue=gv('si-date');INV_DATA.statut=gv('si-statut');INV_STEP=4;renderInvStep();};
    footer.appendChild(btnPrev);footer.appendChild(btnNext);body.appendChild(footer);

  }else if(INV_STEP===4){
    var recap=document.createElement('div');recap.style.cssText='background:#F8F8F8;border-radius:10px;padding:16px;margin-bottom:16px';
    recap.innerHTML='<div style="font-size:13px;font-weight:700;margin-bottom:12px">Récapitulatif</div>';
    [{l:'Magasin',v:INV_DATA.mag+' ('+INV_DATA.code+')'},{l:'Type',v:INV_DATA.motif},{l:'Date',v:fmt(INV_DATA.date_prevue)},{l:'Participants',v:(INV_DATA.personnes||'').replace(/;/g,', ')},{l:'Statut',v:INV_DATA.statut},{l:'Notes',v:INV_DATA.notes||'-'}].forEach(function(r){
      recap.innerHTML+='<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bord2);font-size:12px"><span style="color:#777">'+r.l+'</span><span style="font-weight:600">'+r.v+'</span></div>';
    });
    body.appendChild(recap);
    var footer=document.createElement('div');footer.className='modal-footer';
    var btnPrev=document.createElement('button');btnPrev.className='btn btn-ghost';btnPrev.textContent='← Retour';btnPrev.onclick=function(){INV_STEP=3;renderInvStep();};
    var btnSave=document.createElement('button');btnSave.className='btn btn-primary';btnSave.textContent=INV_DATA._id?'Mettre à jour':'Créer l\'inventaire';
    btnSave.onclick=sauvegarderInv;
    footer.appendChild(btnPrev);footer.appendChild(btnSave);body.appendChild(footer);
  }
}
function sauvegarderInv(){
  var data={code:INV_DATA.code,mag:INV_DATA.mag,date_prevue:INV_DATA.date_prevue,motif:INV_DATA.motif,personnes:INV_DATA.personnes,statut:INV_DATA.statut||'Planifié',notes:INV_DATA.notes||''};
  showL(true);
  var p=INV_DATA._id?api('inventaires_planifies?id=eq.'+INV_DATA._id,{method:'PATCH',body:JSON.stringify(data)}):api('inventaires_planifies',{method:'POST',body:JSON.stringify(data)});
  p.then(function(rows){
    var r=Array.isArray(rows)?rows[0]:rows;
    if(INV_DATA._id){var idx=INVPLAN.findIndex(function(i){return i.id===INV_DATA._id;});if(idx>-1)INVPLAN[idx]=r;}
    else INVPLAN.push(r);
    showL(false);closeM('mod-inv');navTo(CUR_PG);
  }).catch(function(err){showL(false);alert('Erreur : '+err.message);});
}
function supprimerInv(id){
  confirmer('Supprimer cet inventaire ?','Cette action est irréversible.',function(){
    api('inventaires_planifies?id=eq.'+id,{method:'DELETE'}).then(function(){
      INVPLAN=INVPLAN.filter(function(i){return i.id!==id;});navTo(CUR_PG);
    }).catch(function(err){alert('Erreur : '+err.message);});
  });
}

