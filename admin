<script>
// ============================================================
// CONFIG SUPABASE
// ============================================================
var SB='https://btzwrdjgngfpsutegmci.supabase.co';
var KEY='sb_publishable_0vlIW4o7tI847aAQ_8UYsg_FrC3w-Z4';

function api(path,opts){
  var o=opts||{};
  o.headers=Object.assign({apikey:KEY,Authorization:'Bearer '+KEY,'Content-Type':'application/json',Prefer:'return=representation'},o.headers||{});
  return fetch(SB+'/rest/v1/'+path,o).then(function(r){
    if(!r.ok)return r.text().then(function(t){throw new Error(t);});
    var ct=r.headers.get('content-type')||'';
    return ct.indexOf('json')>-1?r.json():r.text();
  });
}

// ============================================================
// ÉTAT GLOBAL
// ============================================================
var MAGS=[],USERS=[],PARAMS={},INVPLAN=[],CONGES=[],INTERVENTIONS=[],INVS=[];
var CU=null;
var CAL_Y=new Date().getFullYear(),CAL_M=new Date().getMonth();
var CUR_PG='calendrier';
var CFM_CB=null;

var MN=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
var JC=['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];

function g(id){return document.getElementById(id);}
function gv(id){var e=g(id);return e?e.value:'';}
function showL(s){g('lov').classList[s?'add':'remove']('on');}
function openM(id){g(id).classList.add('on');}
function closeM(id){g(id).classList.remove('on');}
function fmt(d){if(!d)return'';var dt=new Date(d);return isNaN(dt)?'':dt.toLocaleDateString('fr-FR');}
function fmtEuro(v){if(!v&&v!==0)return'--';return new Intl.NumberFormat('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(v);}
function ini(n){return(n||'?').split(' ').map(function(w){return w[0]||'';}).join('').substring(0,2).toUpperCase();}

// ============================================================
// CHARGEMENT
// ============================================================
function loadData(){
  showL(true);
  Promise.all([
    api('magasins?order=nom'),
    api('utilisateurs?actif=eq.true'),
    api('parametres'),
    api('inventaires_planifies?order=date_prevue.asc'),
    api('conges?order=date_debut.asc'),
    api('interventions?order=date_prevue.asc'),
    api('inventaires?order=date_inventaire.desc&limit=200')
  ]).then(function(res){
    MAGS=res[0]||[];USERS=res[1]||[];
    PARAMS={};(res[2]||[]).forEach(function(p){PARAMS[p.cle]=p.valeur;});
    INVPLAN=res[3]||[];CONGES=res[4]||[];INTERVENTIONS=res[5]||[];INVS=res[6]||[];
    showL(false);
    checkAuth();
  }).catch(function(err){
    showL(false);
    g('content').innerHTML='<div style="text-align:center;padding:40px"><div style="color:var(--rouge);font-size:16px;font-weight:700">Erreur de connexion</div><div style="color:#777;margin-top:8px">'+err.message+'</div><button id="btn-retry" style="margin-top:16px;background:var(--or);color:#fff;border:none;border-radius:8px;padding:10px 20px;cursor:pointer">Réessayer</button></div>';
    var rb=g('btn-retry');if(rb)rb.onclick=function(){location.reload();};
  });
}

function checkAuth(){
  try{
    var s=localStorage.getItem('pp_v1');
