function renderCalendrier(){
  var acts=g('topbar-actions');acts.innerHTML='';
  var btnAdd=document.createElement('button');btnAdd.className='btn btn-primary';btnAdd.innerHTML='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Planifier';
  btnAdd.onclick=function(){ouvrirFormInv();};acts.appendChild(btnAdd);

  var btnExp=document.createElement('button');btnExp.className='btn btn-ghost';btnExp.innerHTML='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Export PDF';
  btnExp.onclick=exportPDF;acts.appendChild(btnExp);

  var c=g('content');c.innerHTML='';
  var calCard=document.createElement('div');calCard.className='card cal-wrap';

  // Nav mois
  var nav=document.createElement('div');nav.className='cal-nav';
  var title=document.createElement('div');title.className='cal-title';title.textContent=MN[CAL_M]+' '+CAL_Y;
  var btns=document.createElement('div');btns.style.cssText='display:flex;gap:6px';
  var bp=document.createElement('button');bp.className='btn btn-ghost btn-sm';bp.textContent='‹';
  bp.onclick=function(){if(CAL_M===0){CAL_M=11;CAL_Y--;}else CAL_M--;renderCalendrier();};
  var bn=document.createElement('button');bn.className='btn btn-ghost btn-sm';bn.textContent='›';
  bn.onclick=function(){if(CAL_M===11){CAL_M=0;CAL_Y++;}else CAL_M++;renderCalendrier();};
  var bt=document.createElement('button');bt.className='btn btn-ghost btn-sm';bt.textContent='Aujourd\'hui';
  bt.onclick=function(){CAL_Y=new Date().getFullYear();CAL_M=new Date().getMonth();renderCalendrier();};
  btns.appendChild(bp);btns.appendChild(bn);btns.appendChild(bt);
  nav.appendChild(title);nav.appendChild(btns);calCard.appendChild(nav);

  // Header jours
  var hdr=document.createElement('div');hdr.className='cal-days-hdr';
  JC.forEach(function(d){var el=document.createElement('div');el.className='cal-dh';el.textContent=d;hdr.appendChild(el);});
  calCard.appendChild(hdr);

  // Grille
  var grid=document.createElement('div');grid.className='cal-grid';
  var fd=new Date(CAL_Y,CAL_M,1);
  var dow=(fd.getDay()+6)%7;
  var dim=new Date(CAL_Y,CAL_M+1,0).getDate();
  var prev=new Date(CAL_Y,CAL_M,0).getDate();
  var today=new Date();today.setHours(0,0,0,0);

  // Indexer événements par date
  var evs={};
  function addEv(ds,ev){if(!evs[ds])evs[ds]=[];evs[ds].push(ev);}

  INVPLAN.forEach(function(inv){
    if(!inv.date_prevue)return;
    var ds=inv.date_prevue.substring(0,10);
    var m=inv.motif||'Inventaire';
    var cls=m==='Cession'?'ev-c':m.indexOf('ntrôle')>-1||m.indexOf('ntrole')>-1?'ev-k':m==='Congés'||m==='Conges'?'ev-cg':m==='Visite'?'ev-vi':'ev-in';
    addEv(ds,{cls:cls,txt:(inv.mag||m).substring(0,14),inv:inv});
  });
  CONGES.forEach(function(cg){
    if(!cg.date_debut)return;
    var d0=new Date(cg.date_debut),d1=new Date(cg.date_fin||cg.date_debut);
    for(var d=new Date(d0);d<=d1;d.setDate(d.getDate()+1)){
      var ds=d.toISOString().substring(0,10);
      addEv(ds,{cls:'ev-cg',txt:(cg.personne_nom||'Congé').substring(0,14),cg:cg});
    }
  });
  INTERVENTIONS.forEach(function(it){
    if(!it.date_prevue)return;
    var ds=it.date_prevue.substring(0,10);
    addEv(ds,{cls:'ev-in',txt:(it.mag||it.type_intervention||'Intervention').substring(0,14),it:it});
  });

  for(var i=0;i<dow;i++){var cc=document.createElement('div');cc.className='cal-cell';var n=document.createElement('div');n.className='cal-num past';n.textContent=prev-dow+i+1;cc.appendChild(n);grid.appendChild(cc);}
  for(var d=1;d<=dim;d++){
    var dt=new Date(CAL_Y,CAL_M,d);
    var isT=dt.getTime()===today.getTime(),isP=dt<today;
    var ds=CAL_Y+'-'+('0'+(CAL_M+1)).slice(-2)+'-'+('0'+d).slice(-2);
    var cc=document.createElement('div');cc.className='cal-cell';
    var numEl=document.createElement('div');numEl.className='cal-num'+(isT?' today':isP?' past':'');numEl.textContent=d;cc.appendChild(numEl);
    (evs[ds]||[]).slice(0,3).forEach(function(ev){
      var el=document.createElement('div');el.className='cal-ev '+ev.cls;el.textContent=ev.txt;
      el.onclick=function(e){e.stopPropagation();afficherDetailEv(ev);};
      cc.appendChild(el);
    });
    if((evs[ds]||[]).length>3){var more=document.createElement('div');more.style.cssText='font-size:7px;color:#999;padding:1px 3px';more.textContent='+'+(evs[ds].length-3)+' autres';cc.appendChild(more);}
    grid.appendChild(cc);
  }
  var rem=(7-((dow+dim)%7))%7;
  for(var nd=1;nd<=rem;nd++){var cc=document.createElement('div');cc.className='cal-cell';var n=document.createElement('div');n.className='cal-num';n.style.color='#DDD';n.textContent=nd;cc.appendChild(n);grid.appendChild(cc);}
  calCard.appendChild(grid);

  // Légende
  var leg=document.createElement('div');leg.className='cal-leg';
  [{l:'Cession',c:'var(--or)'},{l:'Contrôle',c:'var(--vert)'},{l:'Congés',c:'var(--bleu)'},{l:'Intervention',c:'var(--violet)'},{l:'Visite',c:'#999'}].forEach(function(x){
    leg.innerHTML+='<div class="leg-item"><div class="leg-dot" style="background:'+x.c+'"></div>'+x.l+'</div>';
  });
  calCard.appendChild(leg);
  c.appendChild(calCard);

  // Liste des événements du mois
  var evsMois=[];
  for(var d2=1;d2<=dim;d2++){
    var ds2=CAL_Y+'-'+('0'+(CAL_M+1)).slice(-2)+'-'+('0'+d2).slice(-2);
    (evs[ds2]||[]).forEach(function(ev){evsMois.push({date:ds2,ev:ev});});
  }
  // Déduplier les congés (1 entrée par personne max)
  evsMois=evsMois.filter(function(x,i,a){return !x.ev.cg||!a.slice(0,i).some(function(y){return y.ev.cg&&y.ev.cg.id===x.ev.cg.id;});});

  if(evsMois.length){
    var listCard=document.createElement('div');listCard.className='card';
    listCard.innerHTML='<div class="card-hdr"><span class="card-title">Événements — '+MN[CAL_M]+' '+CAL_Y+'</span><span style="font-size:11px;color:#999">'+evsMois.length+' événement(s)</span></div>';
    var tbl=document.createElement('table');
    tbl.innerHTML='<thead><tr><th>Date</th><th>Magasin</th><th>Type</th><th>Participants</th><th>Statut</th><th></th></tr></thead>';
    var tb=document.createElement('tbody');
    evsMois.forEach(function(x){
      var ev=x.ev,d=new Date(x.date);
      var nom='',type='',participants='',statut='',id=null,obj=null;
      if(ev.inv){obj=ev.inv;nom=ev.inv.mag||ev.inv.code||'';type=ev.inv.motif||'Inventaire';participants=ev.inv.personnes||'';statut=ev.inv.statut||'Planifié';id=ev.inv.id;}
      else if(ev.cg){obj=ev.cg;nom=ev.cg.code_mag||'';type='Congés - '+(ev.cg.personne_type==='moniteur'?'Moniteur':'Gérant');participants=ev.cg.personne_nom||'';statut=ev.cg.statut||'';id=ev.cg.id;}
      else if(ev.it){obj=ev.it;nom=ev.it.mag||'';type=ev.it.type_intervention||'Intervention';participants=ev.it.personnes||'';statut=ev.it.statut||'Planifié';id=ev.it.id;}
      var scls=statut==='Réalisé'||statut==='Realise'?'pill-g':statut==='Annulé'||statut==='Annule'?'pill-r':'pill-or';
      var tr=document.createElement('tr');
      tr.innerHTML='<td>'+d.getDate()+' '+MN[d.getMonth()].substring(0,3)+'</td><td><span class="tf">'+(ev.inv?ev.inv.code||'':ev.cg?ev.cg.code_mag||'':ev.it?ev.it.code||'':'')+'</span> '+nom+'</td><td><span class="pill '+(ev.inv?ev.inv.motif==='Cession'?'pill-or':'pill-g':ev.cg?'pill-b':'pill-v')+'">'+type+'</span></td><td style="color:#777">'+participants+'</td><td><span class="pill '+scls+'">'+statut+'</span></td><td><button class="btn btn-ghost btn-sm" data-edit-id="'+id+'" data-edit-type="'+(ev.inv?'inv':ev.cg?'cg':'it')+'">Éditer</button></td>';
      tr.querySelector('td:first-child').onclick=function(){afficherDetailEv(ev);};
      tr.querySelector('[data-edit-id]').onclick=function(e){e.stopPropagation();var t=this.getAttribute('data-edit-type'),id2=parseInt(this.getAttribute('data-edit-id'));if(t==='inv')editerInv(id2);else if(t==='cg')editerConge(id2);else editerIntervention(id2);};
      tb.appendChild(tr);
    });
    tbl.appendChild(tb);listCard.appendChild(tbl);c.appendChild(listCard);
  }
}

