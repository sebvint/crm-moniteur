function afficherDetailEv(ev){
  var title='',body='',footer='';
  if(ev.inv){
    var inv=ev.inv;
    title=(inv.motif||'Inventaire')+' — '+(inv.mag||inv.code||'');
    body='<div style="display:flex;flex-direction:column;gap:8px">';
    [{l:'Magasin',v:(inv.code||'')+' '+( inv.mag||'')},{l:'Type',v:inv.motif||'Inventaire'},{l:'Date prévue',v:fmt(inv.date_prevue)},{l:'Participants',v:(inv.personnes||'-').replace(/;/g,', ')},{l:'Statut',v:inv.statut||'Planifié'},{l:'Notes',v:inv.notes||'-'}].forEach(function(r){
      body+='<div style="display:flex;justify-content:space-between;font-size:12px;padding:6px 0;border-bottom:1px solid var(--bord2)"><span style="color:#777">'+r.l+'</span><span style="font-weight:600">'+r.v+'</span></div>';
    });
    body+='</div>';
  }else if(ev.cg){
    var cg=ev.cg;
    title='Congé — '+( cg.personne_nom||'');
    body='<div style="font-size:12px;display:flex;flex-direction:column;gap:6px">';
    [{l:'Personne',v:cg.personne_nom},{l:'Type',v:cg.personne_type==='moniteur'?'Moniteur':'Gérant'},{l:'Magasin',v:cg.code_mag||'-'},{l:'Du',v:fmt(cg.date_debut)},{l:'Au',v:fmt(cg.date_fin||cg.date_debut)},{l:'Motif',v:cg.motif||'-'}].forEach(function(r){
      body+='<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bord2)"><span style="color:#777">'+r.l+'</span><span style="font-weight:600">'+r.v+'</span></div>';
    });
    body+='</div>';
  }else if(ev.it){
    var it=ev.it;
    title=(it.type_intervention||'Intervention')+' — '+(it.mag||it.code||'');
    body='<div style="font-size:12px;display:flex;flex-direction:column;gap:6px">';
    [{l:'Type',v:it.type_intervention},{l:'Date',v:fmt(it.date_prevue)},{l:'Responsable',v:it.responsable||'-'},{l:'Participants',v:(it.personnes||'-')},{l:'Durée',v:it.duree_prevue?(it.duree_prevue+'h'):'-'},{l:'Statut',v:it.statut||'Planifié'},{l:'Notes',v:it.notes||'-'}].forEach(function(r){
      body+='<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--bord2)"><span style="color:#777">'+r.l+'</span><span style="font-weight:600">'+r.v+'</span></div>';
    });
    body+='</div>';
  }
  g('dev-title').textContent=title;
  g('dev-body').innerHTML=body;
  var ftr=g('dev-footer');ftr.innerHTML='';
  var btnF=document.createElement('button');btnF.className='btn btn-ghost';btnF.textContent='Fermer';btnF.onclick=function(){closeM('mod-detail-ev');};
  ftr.appendChild(btnF);
  if(ev.inv){var btnE=document.createElement('button');btnE.className='btn btn-primary';btnE.textContent='Éditer';btnE.onclick=function(){closeM('mod-detail-ev');editerInv(ev.inv.id);};ftr.appendChild(btnE);}
  openM('mod-detail-ev');
}

// ============================================================
// EXPORT PDF
// ============================================================
function exportPDF(){
  var evsMois=[];
  var dim=new Date(CAL_Y,CAL_M+1,0).getDate();
  var evsIdx={};
  INVPLAN.forEach(function(inv){
    if(!inv.date_prevue)return;
    var d=new Date(inv.date_prevue);
    if(d.getFullYear()!==CAL_Y||d.getMonth()!==CAL_M)return;
    var ds=inv.date_prevue.substring(0,10);
    if(!evsIdx[ds])evsIdx[ds]=[];
    evsIdx[ds].push({type:'inv',obj:inv});
  });
  CONGES.forEach(function(cg){
    if(!cg.date_debut)return;
    var d=new Date(cg.date_debut);
    if(d.getFullYear()!==CAL_Y||d.getMonth()!==CAL_M)return;
    var ds=cg.date_debut.substring(0,10);
    if(!evsIdx[ds])evsIdx[ds]=[];
    evsIdx[ds].push({type:'cg',obj:cg});
  });
  for(var d=1;d<=dim;d++){
    var ds=CAL_Y+'-'+('0'+(CAL_M+1)).slice(-2)+'-'+('0'+d).slice(-2);
    (evsIdx[ds]||[]).forEach(function(ev){evsMois.push({date:ds,ev:ev});});
  }

  var w=window.open('','_blank');
  var html='<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Planning '+MN[CAL_M]+' '+CAL_Y+'</title><style>body{font-family:Arial,sans-serif;font-size:11px;color:#111;margin:20px}h1{font-size:16px;color:#C9921A;margin-bottom:4px}h2{font-size:13px;color:#333;margin-top:20px;margin-bottom:8px;border-bottom:1px solid #eee;padding-bottom:4px}table{width:100%;border-collapse:collapse;margin-bottom:16px}th{background:#111;color:#C9921A;padding:6px 8px;text-align:left;font-size:10px}td{padding:6px 8px;border-bottom:1px solid #eee;vertical-align:top}tr:nth-child(even)td{background:#FAFAFA}.badge{display:inline-block;padding:1px 6px;border-radius:10px;font-size:9px;font-weight:700}.or{background:#FDF7E8;color:#C9921A;border:1px solid #E8D080}.gr{background:#F0F9F4;color:#2E8050;border:1px solid #98D0B0}.bl{background:#EFF6FF;color:#1D4ED8;border:1px solid #93C5FD}.vl{background:#F5F3FF;color:#5B21B6;border:1px solid #C4B5FD}</style></head><body>';
  html+='<h1>Planning — '+MN[CAL_M]+' '+CAL_Y+'</h1>';
  html+='<div style="color:#777;font-size:10px;margin-bottom:16px">Généré le '+new Date().toLocaleDateString('fr-FR')+' — Secteur : '+(PARAMS.SECTEUR||'')+'</div>';
  html+='<h2>Événements du mois</h2>';
  if(evsMois.length){
    html+='<table><thead><tr><th>Date</th><th>Magasin</th><th>Type</th><th>Participants</th><th>Statut</th><th>Notes</th></tr></thead><tbody>';
    evsMois.forEach(function(x){
      var ev=x.ev,obj=ev.obj;
      var date=fmt(x.date),mag='',type='',pers='',stat='',notes='',cls='or';
      if(ev.type==='inv'){mag=(obj.code||'')+' '+(obj.mag||'');type=obj.motif||'Inventaire';pers=(obj.personnes||'').replace(/;/g,', ');stat=obj.statut||'Planifié';notes=obj.notes||'';cls=obj.motif==='Cession'?'or':'gr';}
      else if(ev.type==='cg'){mag=obj.code_mag||'-';type='Congés';pers=obj.personne_nom||'';stat=obj.statut||'';notes=obj.motif||'';cls='bl';}
      else if(ev.type==='it'){mag=(obj.code||'')+' '+(obj.mag||'');type=obj.type_intervention||'Intervention';pers=obj.personnes||'';stat=obj.statut||'';notes=obj.notes||'';cls='vl';}
      html+='<tr><td>'+date+'</td><td>'+mag+'</td><td><span class="badge '+cls+'">'+type+'</span></td><td style="font-style:italic">'+pers+'</td><td>'+stat+'</td><td>'+notes+'</td></tr>';
    });
    html+='</tbody></table>';
  }else{html+='<p style="color:#CCC">Aucun événement ce mois</p>';}

  var cgsM=CONGES.filter(function(cg){var d=new Date(cg.date_debut);return d.getFullYear()===CAL_Y&&d.getMonth()===CAL_M;});
  if(cgsM.length){
    html+='<h2>Congés</h2><table><thead><tr><th>Personne</th><th>Type</th><th>Période</th><th>Motif</th></tr></thead><tbody>';
    cgsM.forEach(function(cg){html+='<tr><td>'+( cg.personne_nom||'')+'</td><td>'+(cg.personne_type==='moniteur'?'Moniteur':'Gérant')+'</td><td>'+fmt(cg.date_debut)+' → '+fmt(cg.date_fin||cg.date_debut)+'</td><td>'+(cg.motif||'')+'</td></tr>';});
    html+='</tbody></table>';
  }

  var aPlanner=MAGS.filter(function(m){return m.statut==='Actif'&&!INVPLAN.some(function(i){var d=new Date(i.date_prevue);return i.code===m.code&&d.getFullYear()===CAL_Y&&d.getMonth()===CAL_M;});});
  if(aPlanner.length){
    html+='<h2>Inventaires à programmer</h2><table><thead><tr><th>Magasin</th><th>Ville</th><th>Fréquence</th></tr></thead><tbody>';
    aPlanner.slice(0,10).forEach(function(m){html+='<tr><td><span style="background:#111;color:#C9921A;padding:1px 5px;border-radius:3px;font-size:9px">'+m.code+'</span> '+m.nom+'</td><td>'+( m.ville||'')+'</td><td>'+( m.freq_n?'Tous les '+m.freq_n+'j':'Non définie')+'</td></tr>';});
    html+='</tbody></table>';
  }

  html+='</body></html>';
  w.document.write(html);w.document.close();
  setTimeout(function(){w.print();},500);
}

