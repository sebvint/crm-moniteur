  var btnSave=document.createElement('button');btnSave.className='btn btn-primary';btnSave.textContent='Créer';
  btnSave.onclick=function(){
    var sel=g('it-mag');if(!sel||!sel.value||!gv('it-date')){alert('Magasin et date obligatoires');return;}
    var opt=sel.options[sel.selectedIndex];
    var data={code:sel.value,mag:opt.getAttribute('data-nom')||sel.value,date_prevue:gv('it-date'),type_intervention:gv('it-type'),responsable:gv('it-resp'),personnes:gv('it-pers'),duree_prevue:parseFloat(gv('it-duree'))||null,statut:'Planifié',notes:gv('it-notes')};
    showL(true);api('interventions',{method:'POST',body:JSON.stringify(data)}).then(function(rows){
      var r=Array.isArray(rows)?rows[0]:rows;INTERVENTIONS.push(r);showL(false);closeM('mod-inter');navTo(CUR_PG);
    }).catch(function(err){showL(false);alert('Erreur : '+err.message);});
  };
  footer.appendChild(btnAnn);footer.appendChild(btnSave);body.appendChild(footer);
  openM('mod-inter');
}
function editerIntervention(id){ouvrirFormIntervention();}
function supprimerIntervention(id){
  confirmer('Supprimer cette intervention ?','',function(){
    api('interventions?id=eq.'+id,{method:'DELETE'}).then(function(){
      INTERVENTIONS=INTERVENTIONS.filter(function(i){return i.id!==id;});navTo(CUR_PG);
    }).catch(function(err){alert('Erreur : '+err.message);});
  });
}

// ============================================================
// FORMULAIRE UTILISATEUR
// ============================================================
function ouvrirFormUser(id){
  var u=id?USERS.find(function(u){return u.id===id;}):null;
  g('mod-usr-title').textContent=u?'Modifier '+u.nom:'Créer un utilisateur';
  var body=g('mod-usr-body');body.innerHTML='';
  var selRole=document.createElement('select');selRole.id='usr-role';
  ['Moniteur','Admin','Lecteur'].forEach(function(r){var o=document.createElement('option');o.value=r;o.textContent=r;if(u&&u.role===r)o.selected=true;selRole.appendChild(o);});
  [['usr-nom','Nom complet *','text',u?u.nom:''],['usr-pin','Code PIN (4 chiffres) *','text',u?u.pin:''],['usr-couleur','Couleur (hex)','text',u?u.couleur:'#C9921A'],['usr-secteur','Secteur','text',u?u.secteur||'':'']].forEach(function(f){
    var ff=document.createElement('div');ff.className='ff';ff.style.marginBottom='10px';ff.innerHTML='<label class="fl">'+f[1]+'</label><input type="'+f[2]+'" id="'+f[0]+'" value="'+f[3]+'">';body.appendChild(ff);
  });
  var ffRole=document.createElement('div');ffRole.className='ff';ffRole.style.marginBottom='10px';ffRole.innerHTML='<label class="fl">Rôle</label>';ffRole.appendChild(selRole);body.appendChild(ffRole);
  var footer=document.createElement('div');footer.className='modal-footer';
  var btnAnn=document.createElement('button');btnAnn.className='btn btn-ghost';btnAnn.textContent='Annuler';btnAnn.onclick=function(){closeM('mod-user');};
  var btnSave=document.createElement('button');btnSave.className='btn btn-primary';btnSave.textContent=u?'Mettre à jour':'Créer';
  btnSave.onclick=function(){
    var pin=gv('usr-pin');if(!/^\d{4}$/.test(pin)){alert('Le PIN doit être 4 chiffres');return;}
    var data={nom:gv('usr-nom'),pin:pin,role:gv('usr-role'),couleur:gv('usr-couleur'),secteur:gv('usr-secteur'),actif:true};
    if(!data.nom){alert('Nom obligatoire');return;}
    showL(true);
    var p=u?api('utilisateurs?id=eq.'+u.id,{method:'PATCH',body:JSON.stringify(data)}):api('utilisateurs',{method:'POST',body:JSON.stringify(data)});
    p.then(function(rows){
      var r=Array.isArray(rows)?rows[0]:rows;
      if(u){var idx=USERS.findIndex(function(x){return x.id===u.id;});if(idx>-1)USERS[idx]=r;}
      else USERS.push(r);
      showL(false);closeM('mod-user');renderUtilisateurs();
    }).catch(function(err){showL(false);alert('Erreur : '+err.message);});
  };
  footer.appendChild(btnAnn);footer.appendChild(btnSave);body.appendChild(footer);
  openM('mod-user');
}

